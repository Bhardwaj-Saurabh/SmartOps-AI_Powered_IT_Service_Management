# Copy to .env.local (gitignored) and fill in the values.
# .env.local is mounted into the LiteLLM and Keycloak containers only —
# agent containers never see provider keys.

# ─── Azure AI Foundry (for LiteLLM) ──────────────────────────────────
# Get these from your Foundry deployment. Both a chat AND an embedding
# deployment are required (see docs/architecture.md "Open decisions" #5).
AZURE_FOUNDRY_ENDPOINT=https://your-foundry-resource.openai.azure.com/
AZURE_FOUNDRY_API_KEY=replace-me
AZURE_FOUNDRY_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_FOUNDRY_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_FOUNDRY_API_VERSION=2024-10-21

# ─── LiteLLM (gateway) ───────────────────────────────────────────────
# Master key is only used for admin operations on the gateway itself.
# Agents authenticate to LiteLLM with Keycloak JWTs, not this key.
LITELLM_MASTER_KEY=sk-litellm-master-rotate-me

# Optional: pin the LiteLLM image by digest after first verified pull
# LITELLM_IMAGE=ghcr.io/berriai/litellm@sha256:...

# ─── Keycloak ────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-rotate-me

# ─── Agent service-account credentials (issued by Keycloak) ──────────
# Used by agents to obtain JWTs via client-credentials flow.
# Defaults below match infra/keycloak/realm-export.json — rotate before any non-local use.
INCIDENT_INTAKE_CLIENT_SECRET=dev-incident-intake-secret-rotate-me
SBCA_CLIENT_SECRET=dev-sbca-secret-rotate-me
CLASSIFICATION_CLIENT_SECRET=dev-classification-secret-rotate-me
PRIORITY_SCORER_CLIENT_SECRET=dev-priority-scorer-secret-rotate-me
ROUTING_CLIENT_SECRET=dev-routing-secret-rotate-me
DIAGNOSTIC_CLIENT_SECRET=dev-diagnostic-secret-rotate-me
KNOWLEDGE_SEARCH_CLIENT_SECRET=dev-knowledge-search-secret-rotate-me
TRIAGE_ORCHESTRATOR_CLIENT_SECRET=dev-triage-orchestrator-secret-rotate-me
RESOLUTION_ORCHESTRATOR_CLIENT_SECRET=dev-resolution-orchestrator-secret-rotate-me
AUTOMATED_FIX_CLIENT_SECRET=dev-automated-fix-secret-rotate-me
VERIFICATION_CLIENT_SECRET=dev-verification-secret-rotate-me
COMMUNICATION_CLIENT_SECRET=dev-communication-secret-rotate-me
SLA_MONITOR_CLIENT_SECRET=dev-sla-monitor-secret-rotate-me
CLOSURE_ORCHESTRATOR_CLIENT_SECRET=dev-closure-orchestrator-secret-rotate-me
RESOLUTION_DOCUMENTER_CLIENT_SECRET=dev-resolution-documenter-secret-rotate-me
PROBLEM_LINKER_CLIENT_SECRET=dev-problem-linker-secret-rotate-me

# ─── Test/demo knobs ─────────────────────────────────────────────────
# Set to a non-negative integer (e.g. 0) to force the script-executor to
# fail at that step index. Used by the Saga-rollback integration demo.
SIMULATE_RUNBOOK_FAILURE_AT_STEP=-1
